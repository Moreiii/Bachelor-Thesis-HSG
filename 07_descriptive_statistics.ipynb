   "source": [
    "# Descriptive statistics \u2014 Original-today vs Pro-forma\n",
       ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "cell_010",
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "\n",
    "PROJECT_DIR = r'C:\\Users\\name\\Documents\\Bachelor Thesis\\Empirical Analysis'\n",
    "DATA_DIR    = os.path.join(PROJECT_DIR, 'data')\n",
    "OUT_CSV     = os.path.join(PROJECT_DIR, 'descriptive_statistics.csv')\n",
    "OUT_TOPSEC  = os.path.join(PROJECT_DIR, 'descriptive_top_sectors.csv')\n",
    "\n",
    "def _load_num(main, gap=None):\n",
    "    frames = []\n",
    "    for fn in (main, gap):\n",
    "        if fn and os.path.exists(os.path.join(DATA_DIR, fn)):\n",
    "            frames.append(pd.read_parquet(os.path.join(DATA_DIR, fn)))\n",
    "    if not frames:\n",
    "        return pd.DataFrame()\n",
    "    df = pd.concat(frames, axis=1)\n",
    "    df = df.loc[:, ~df.columns.duplicated()]\n",
    "    return df.apply(pd.to_numeric, errors='coerce').astype(float)\n",
    "\n",
    "def compute_adtv(df_px, df_vol):\n",
    "    common = df_px.columns.intersection(df_vol.columns)\n",
    "    if not len(common):\n",
    "        return pd.Series(dtype=float)\n",
    "    turnover = df_px[common] * df_vol[common]\n",
    "    return turnover.mean(axis=0, skipna=True)\n",
    "\n",
    "def _basic(series, scale=1.0):\n",
    "    s = pd.to_numeric(series, errors='coerce').dropna() * scale\n",
    "    if s.empty:\n",
    "        return dict(N=0, mean=np.nan, median=np.nan, min=np.nan, max=np.nan)\n",
    "    return dict(N=int(s.size), mean=float(s.mean()), median=float(s.median()),\n",
    "                min=float(s.min()), max=float(s.max()))\n",
    "\n",
    "def _attach_freefloat(df, meta_fn):\n",
    "    \"\"\"Merge FreeFloatPct onto df via RIC from the corresponding meta parquet.\n",
    "    If the df already has a populated FreeFloatPct we keep it; otherwise fill\n",
    "    from meta.\"\"\"\n",
    "    fp = os.path.join(DATA_DIR, meta_fn)\n",
    "    if not os.path.exists(fp):\n",
    "        return df\n",
    "    m = pd.read_parquet(fp)\n",
    "    if 'RIC' not in m.columns or 'FreeFloatPct' not in m.columns:\n",
    "        return df\n",
    "    ff_map = (m[['RIC', 'FreeFloatPct']]\n",
    "              .dropna(subset=['FreeFloatPct'])\n",
    "              .drop_duplicates('RIC')\n",
    "              .set_index('RIC')['FreeFloatPct'])\n",
    "    if 'FreeFloatPct' not in df.columns:\n",
    "        df = df.copy()\n",
    "        df['FreeFloatPct'] = df['RIC'].map(ff_map)\n",
    "    else:\n",
    "        df = df.copy()\n",
    "        na = df['FreeFloatPct'].isna()\n",
    "        df.loc[na, 'FreeFloatPct'] = df.loc[na, 'RIC'].map(ff_map)\n",
    "    return df\n",
    "\n",
    "def index_stats(df, adtv_map, overlap_rics, label):\n",
    "    out = {}\n",
    "    rics = set(df['RIC'].astype(str))\n",
    "    out['N constituents (working universe)'] = len(df)\n",
    "    out['N overlap with other index'] = len(rics & overlap_rics)\n",
    "    out['N unique to this index']      = len(rics - overlap_rics)\n",
    "\n",
    "    ff_bn = _basic(df['FF_MktCap'], scale=1e-9)\n",
    "    out['FF MktCap mean (\u00a5bn)']   = ff_bn['mean']\n",
    "    out['FF MktCap median (\u00a5bn)'] = ff_bn['median']\n",
    "    out['FF MktCap min (\u00a5bn)']    = ff_bn['min']\n",
    "    out['FF MktCap max (\u00a5bn)']    = ff_bn['max']\n",
    "\n",
    "    adtv_series = df['RIC'].map(adtv_map)\n",
    "    adtv_m = _basic(adtv_series, scale=1e-6)\n",
    "    out['ADTV mean (\u00a5m)']   = adtv_m['mean']\n",
    "    out['ADTV median (\u00a5m)'] = adtv_m['median']\n",
    "    out['ADTV coverage']    = f'{int(adtv_series.notna().sum())} / {len(df)}'\n",
    "\n",
    "    if 'FreeFloatPct' in df.columns:\n",
    "        ff_raw = pd.to_numeric(df['FreeFloatPct'], errors='coerce').dropna()\n",
    "        scale_ff = 100.0 if (not ff_raw.empty and ff_raw.max() <= 1.01) else 1.0\n",
    "        ff_pct = _basic(df['FreeFloatPct'], scale=scale_ff)\n",
    "        out['FreeFloat mean (%)']   = ff_pct['mean']\n",
    "        out['FreeFloat median (%)'] = ff_pct['median']\n",
    "        out['FreeFloat coverage']   = f'{int(ff_raw.size)} / {len(df)}'\n",
    "    else:\n",
    "        out['FreeFloat mean (%)']   = np.nan\n",
    "        out['FreeFloat median (%)'] = np.nan\n",
    "        out['FreeFloat coverage']   = f'0 / {len(df)}'\n",
    "\n",
    "    ff = pd.to_numeric(df['FF_MktCap'], errors='coerce').fillna(0.0).to_numpy()\n",
    "    tot = ff.sum()\n",
    "    if tot > 0:\n",
    "        w = np.sort(ff / tot)[::-1]\n",
    "        out['Top 10 weight (%)']   = float(w[:10].sum() * 100)\n",
    "        out['Top 20 weight (%)']   = float(w[:20].sum() * 100)\n",
    "        out['Top 50 weight (%)']   = float(w[:50].sum() * 100)\n",
    "        out['HHI (weights, x1e4)'] = float((w ** 2).sum() * 1e4)\n",
    "    else:\n",
    "        out['Top 10 weight (%)']   = np.nan\n",
    "        out['Top 20 weight (%)']   = np.nan\n",
    "        out['Top 50 weight (%)']   = np.nan\n",
    "        out['HHI (weights, x1e4)'] = np.nan\n",
    "\n",
    "    sec_col = 'TRBC_Industry'\n",
    "    d = df[[sec_col, 'FF_MktCap']].copy()\n",
    "    d[sec_col]     = d[sec_col].fillna('Unclassified').astype(str)\n",
    "    d['FF_MktCap'] = pd.to_numeric(d['FF_MktCap'], errors='coerce').fillna(0.0)\n",
    "    if d['FF_MktCap'].sum() > 0:\n",
    "        sec_w = (d.groupby(sec_col)['FF_MktCap'].sum()\n",
    "                 / d['FF_MktCap'].sum() * 100).sort_values(ascending=False)\n",
    "    else:\n",
    "        sec_w = pd.Series(dtype=float)\n",
    "    top5 = sec_w.head(5)\n",
    "    for i, (name, w_pct) in enumerate(top5.items(), start=1):\n",
    "        out[f'Sector {i} name']     = name\n",
    "        out[f'Sector {i} weight %'] = float(w_pct)\n",
    "    for i in range(len(top5) + 1, 6):\n",
    "        out[f'Sector {i} name']     = ''\n",
    "        out[f'Sector {i} weight %'] = np.nan\n",
    "    return out, sec_w.head(10)\n",
    "\n",
    "# ---- Load & filter to working universe -------------------------------------\n",
    "orig_raw = pd.read_parquet(os.path.join(DATA_DIR, 'constituents_original_today.parquet'))\n",
    "pf_raw   = pd.read_parquet(os.path.join(DATA_DIR, 'constituents_proforma.parquet'))\n",
    "\n",
    "print(f'Raw counts   : orig {len(orig_raw):,}   pf {len(pf_raw):,}')\n",
    "orig = orig_raw[orig_raw['FF_MktCap'].notna()].copy()\n",
    "pf   = pf_raw  [pf_raw  ['FF_MktCap'].notna()].copy()\n",
    "print(f'Working univ.: orig {len(orig):,}   pf {len(pf):,}   '\n",
    "      f'(dropped {len(orig_raw)-len(orig):,} / {len(pf_raw)-len(pf):,} with NaN FF_MktCap)')\n",
    "\n",
    "# Merge FreeFloatPct from meta parquets (pf constituents parquet lacks the column)\n",
    "orig = _attach_freefloat(orig, 'meta_original_today.parquet')\n",
    "pf   = _attach_freefloat(pf,   'meta_proforma.parquet')\n",
    "print(f'FreeFloat coverage after merge: '\n",
    "      f\"orig {orig['FreeFloatPct'].notna().sum()}/{len(orig)}   \"\n",
    "      f\"pf {pf['FreeFloatPct'].notna().sum()}/{len(pf)}\")\n",
    "\n",
    "# ---- ADTV from robust-window price \u00d7 volume --------------------------------\n",
    "df_px  = _load_num('prices_robust.parquet', 'prices_robust_gap.parquet')\n",
    "df_vol = _load_num('volume_robust.parquet', 'volume_robust_gap.parquet')\n",
    "adtv_map = compute_adtv(df_px, df_vol)\n",
    "print(f'ADTV computed for {adtv_map.notna().sum():,} RICs '\n",
    "      f'(prices {df_px.shape}, volume {df_vol.shape})')\n",
    "\n",
    "orig_rics = set(orig['RIC'].astype(str))\n",
    "pf_rics   = set(pf['RIC'].astype(str))\n",
    "\n",
    "row_o, sec_o = index_stats(orig, adtv_map, pf_rics,   'Original')\n",
    "row_p, sec_p = index_stats(pf,   adtv_map, orig_rics, 'Pro-forma')\n",
    "overlap_n = len(orig_rics & pf_rics)\n",
    "row_o['N overlap with other index'] = overlap_n\n",
    "row_p['N overlap with other index'] = overlap_n\n",
    "\n",
    "keys = list(row_o.keys())\n",
    "out = pd.DataFrame({'Metric': keys,\n",
    "                    'Original-today': [row_o[k] for k in keys],\n",
    "                    'Pro-forma':      [row_p[k] for k in keys]})\n",
    "out.to_csv(OUT_CSV, index=False, encoding='utf-8-sig')\n",
    "\n",
    "long_o = sec_o.reset_index(); long_o.columns = ['Sector', 'Weight %']\n",
    "long_o.insert(0, 'Index', 'Original-today')\n",
    "long_p = sec_p.reset_index(); long_p.columns = ['Sector', 'Weight %']\n",
    "long_p.insert(0, 'Index', 'Pro-forma')\n",
    "pd.concat([long_o, long_p], ignore_index=True).to_csv(\n",
    "    OUT_TOPSEC, index=False, encoding='utf-8-sig')\n",
    "\n",
    "print(f'[OK] wrote {OUT_CSV}')\n",
    "print(f'[OK] wrote {OUT_TOPSEC}')\n",
    "out"
   ]
  }
 ],
